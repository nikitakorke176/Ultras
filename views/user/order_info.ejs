<%- include("Navbar.ejs") %>



    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">



<div id="print_area" class="container mt-5">

     <style>
        body {
            background-color: #f5f5f5;
        }
        .invoice-box {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
        }
        .title {
            font-size: 28px;
            font-weight: bold;
            letter-spacing: 2px;
        }
        .section-title {
            font-weight: 600;
            margin-bottom: 10px;
        }
        .table th {
            background-color: #f8f9fa;
        }
        .total-box {
            text-align: right;
            font-size: 18px;
            font-weight: bold;
        }
    </style>

    <div class="invoice-box">

        <!-- Header -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="title">ULTRAS</div>
            </div>
            <div class="col-md-6 text-end">
                <div class="section-title">Payment Details</div>
                <p class="mb-1">Bank Name: 01234567891</p>
                <p class="mb-1">Account Number: 012345678901</p>
                <p class="mb-1">SWIFT Code: SWITCH012345678CODE</p>
                <p class="mb-0">VAT Reg #: VAT123456789CODE</p>
            </div>
        </div>

        <!-- Customer Info -->
        <div class="row mb-4">
            <div class="col-md-12">
                <p><strong>First Name:</strong> Nikita Vinayak Korke</p>
                <p><strong>Contact:</strong> +91 49329153</p>
                <p><strong>Address:</strong> Maharashtra, Nagar, Ahmednagar, Nannaj, 414001</p>
                <p><strong>DOB:</strong> YYYY/MM/DD</p>
            </div>
        </div>

        <hr>

        <!-- Items Table -->
        <table class="table table-bordered mt-3">
            <thead>
                <tr>
                    <th>Item Name</th>
                    <th width="120">Quantity</th>
                    <th width="120">Rate</th>
                    <th width="150">Total Price</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        Unique side and front panel design <br>
                        <small class="text-muted">Lorem ipsum dolor sit amet.</small>
                    </td>
                    <td>2</td>
                    <td>₹ 20.00</td>
                    <td>₹ 23.78</td>
                </tr>
            </tbody>
        </table>

        <!-- Total -->
        <div class="row mt-4">
            <div class="col-md-12 total-box">
                Grand Total: ₹ 23.78
            </div>
        </div>

       
    </div>

     <div class="container" style="margin-top: 30px;">
            <div class="row">
                <div class="col-md-12 text-center">
                    <button onclick="printing()">Print</button>
                </div>
            </div>
        </div>
</div>

<script>
    function printing(){
var printContents=document.getElementById("print_area").innerHTML;
var originalContents=document.body.innerHTML;

document.body.innerHTML = printContents;
window.print();
document.body.innerHTML = originalContents;
      
    }
</script>


