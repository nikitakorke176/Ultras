<%- include("Navbar.ejs") %>

<form action="/admin/save_product" method="post" enctype="multipart/form-data">

<div class="container mt-4">

    <!-- Header -->
    <div class="row mb-3">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-body bg-primary text-white">
                    <h3 class="mb-0">Add Product</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row">

        <!-- LEFT SIDE -->
        <div class="col-md-8">

            <div class="card shadow-sm mb-3">
                <div class="card-body">

                    <div class="row g-3">

                        <div class="col-md-4">
                            <label class="form-label">Category <span class="text-danger">*</span></label>
                           <select name="category_id" id="">
                            <option value=""></option>
                            <% category.map(function(val,i){ %>
                                <option value="<%= val.category_id %>"><%= val.category_name %></option>

                           <% }) %>
                           </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input class="form-control" type="text" name="product_name">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Color <span class="text-danger">*</span></label>
                            <input class="form-control" type="text" name="product_color">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Product Label <span class="text-danger">*</span></label>
                            <select class="form-control" name="product_tag">
                                <option>----- Select label -----</option>
                                <option>Featured</option>
                                <option>Best Selling</option>
                                <option>Flash selling</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Company <span class="text-danger">*</span></label>
                            <input class="form-control" type="text" name="product_company">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Image 1 <span class="text-danger">*</span></label>
                            <input class="form-control" type="file" name="product_image1" required>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Image 2 <span class="text-danger">*</span></label>
                            <input class="form-control" type="file" name="product_image2" required>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Image 3</label>
                            <input class="form-control" type="file" name="product_image3">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Image 4</label>
                            <input class="form-control" type="file" name="product_image4">
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Product Details <span class="text-danger">*</span></label>
                            <textarea class="form-control" name="product_detailes" rows="3"></textarea>
                        </div>

                        <div class="col-md-12 text-end">
                            <button class="btn btn-success px-4">Save Product</button>
                        </div>

                    </div>

                </div>
            </div>

        </div>

        <!-- RIGHT SIDE -->
        <div class="col-md-4">

            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white text-center">
                    <h5 class="mb-0">Add Price</h5>
                </div>

                <div class="card-body p-2">

                    <% var size=['S','M','L','XL','XXL']; %>

                    <table class="table table-bordered table-hover text-center align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Size</th>
                                <th>Price</th>
                                <th>Final Price</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% size.map(function(item,i){ %>
                            <tr>
                                <td class="fw-bold"><%= item %> <input type="hidden" name="product_size" value="<%= item %>">
                                <td>
                                    <input class="form-control form-control-sm" type="text" name="product_price">
                                </td>
                                <td>
                                    <input class="form-control form-control-sm" type="text" name="product_duplicate_price">
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>

                </div>
            </div>

        </div>

    </div>

</div>

</form>

<%- include("Footer.ejs") %>