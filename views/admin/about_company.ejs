

  <%- include("Navbar.ejs") %>

<div class="container mt-4">

    <div class="card shadow">
        <div class="card-header bg-primary text-white text-center">
            <h3>About Company</h3>
        </div>

        <div class="card-body">

            <form action="/admin/save_company" method="post">

                <div class="row g-3">

                    <div class="col-md-4 fw-bold  mt-2">
                        <label>Company Name </label>
                        <input type="text" name="company_name" class="form-control" value="<%= about_company[0].company_name %>" >
                    </div>

                    <div class="col-md-8">
                        <label>Company Address</label>
                        <input type="text" name="company_address" class="form-control" value="<%= about_company[0].company_address %>">
                    </div>

                    <div class="col-md-4 fw-bold  mt-2">
                        <label>Company Email</label>
                        <input type="email" name="company_email" class="form-control" value="<%= about_company[0].company_email %>">
                    </div>

                    <div class="col-md-4">
                        <label>Company Mobile</label>
                        <input type="number" name="company_mobile" class="form-control" value="<%= about_company[0].company_mobile %>">
                    </div>

                    <div class="col-md-4">
                        <label>WhatsApp Number</label>
                        <input type="number" name="company_whatsapp_no" class="form-control" value="<%= about_company[0].company_whatsapp_no %>">
                    </div>

                    <div class="col-md-3">
                        <label>Instagram</label>
                        <input type="text" name="instagram" class="form-control" value="<%= about_company[0].instagram %>">
                    </div>

                    <div class="col-md-3">
                        <label>Twitter</label>
                        <input type="text" name="twitter" class="form-control" value="<%= about_company[0].twitter %>">
                    </div>

                    <div class="col-md-3">
                        <label>Youtube</label>
                        <input type="text" name="youtube" class="form-control" value="<%= about_company[0].youtube %>">
                    </div>

                    <div class="col-md-3">
                        <label>Facebook</label>
                        <input type="text" name="facebook" class="form-control" value="<%= about_company[0].facebook %>">
                    </div>

                    <div class="col-md-12 text-center mt-3">
                        <button class="btn btn-success px-4">
                            Save Company Info
                        </button>
                    </div>

                </div>

            </form>

        </div>
    </div>

</div>

<%- include("Footer.ejs") %>